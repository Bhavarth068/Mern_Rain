# Rain Forecasting System — Backend Environment Variables
# Copy this file to .env and fill in real values

# ─── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── MongoDB Atlas ─────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rain_forecasting?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── OpenWeatherMap API ────────────────────────────────────
# Free key from: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# ─── WeatherAPI (optional secondary source) ────────────────
WEATHERAPI_KEY=your_weatherapi_key_here

# ─── Python ML Microservice ────────────────────────────────
ML_SERVICE_URL=http://localhost:5001

# ─── AWS (Production) ──────────────────────────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=rain-forecasting-frontend
